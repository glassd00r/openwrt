Overclock MT7988 to 2Ghz
---
--- a/arch/arm64/boot/dts/mediatek/mt7988a.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7988a.dtsi 
@@ -120,7 +120,11 @@
 			opp-1800000000 {
 				opp-hz = /bits/ 64 <1800000000>;
 				opp-microvolt = <900000>;
 			};
+			opp-2000000000 {
+				opp-hz = /bits/ 64 <2000000000>;
+				opp-microvolt = <900000>;
+			};
 		};
 	};
