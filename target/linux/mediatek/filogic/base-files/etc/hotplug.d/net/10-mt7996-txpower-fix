#!/bin/sh
# Cold-boot TX power fix for MT7992.
# Based on: https://github.com/woziwrt/mt7996-wifi7-manager

[ "$ACTION" = "add" ] || exit 0
[ "$INTERFACE" = "phy0.0-ap0" ] || exit 0

_restore() {
	local radio=$1
	local txpower
	txpower=$(uci -q get wireless.radio${radio}.txpower)
	iw dev phy0.${radio}-ap0 set txpower fixed 1900
	sleep 1
	if [ -n "$txpower" ]; then
		iw dev phy0.${radio}-ap0 set txpower fixed ${txpower}00
	else
		iw dev phy0.${radio}-ap0 set txpower auto
	fi
}

(
	while [ "$(cat /sys/kernel/debug/ieee80211/phy0/mt76/sku_disable 2>/dev/null)" != "0" ]; do
		sleep 2
	done
	_restore 0
	sleep 1
	_restore 1
) &
