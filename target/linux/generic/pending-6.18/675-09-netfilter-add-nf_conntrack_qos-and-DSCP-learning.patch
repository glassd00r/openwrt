+static void
+nft_flow_offload_dscp_init(struct flow_offload *flow, const struct nf_conn *ct,
+			   enum ip_conntrack_dir dir)
+{
+	struct nf_conn_qos *qos;
+
+	qos = nf_conn_qos_find(ct);
+	if (!qos)
+		return;
+
+	flow->tuplehash[dir].tuple.dscp =
+		FIELD_GET(INET_DSCP_MASK, qos->tos[dir].value);
+	flow->tuplehash[!dir].tuple.dscp =
+		FIELD_GET(INET_DSCP_MASK, qos->tos[!dir].value);
+}
+
 static enum flow_offload_xmit_type nft_xmit_type(struct dst_entry *dst)
 {
 	if (dst_xfrm(dst))
@@ -483,6 +501,11 @@
 	struct flow_offload *flow;
 	enum ip_conntrack_dir dir;
 	struct nf_conn *ct;
+	struct nf_conn_qos *qos;
+	struct ipv6hdr *ip6h;
+	struct iphdr *iph;
+	u32 thoff;
+	u8 tos = 0;
 	int ret;
 
 	if (nft_flow_offload_skip(pkt->skb, nft_pf(pkt)))
@@ -494,7 +517,14 @@
 
 	switch (ct->tuplehash[IP_CT_DIR_ORIGINAL].tuple.dst.protonum) {
 	case IPPROTO_TCP:
-		tcph = skb_header_pointer(pkt->skb, nft_thoff(pkt),
+		thoff = nft_thoff(pkt);
+		if (!thoff) {
+			if (pkt->skb->protocol == htons(ETH_P_IP))
+				thoff = ip_hdrlen(pkt->skb);
+			else if (pkt->skb->protocol == htons(ETH_P_IPV6))
+				thoff = sizeof(struct ipv6hdr);
+		}
+		tcph = skb_header_pointer(pkt->skb, thoff,
 					  sizeof(_tcph), &_tcph);
 		if (unlikely(!tcph || tcph->fin || tcph->rst ||
 			     !nf_conntrack_tcp_established(ct)))
@@ -526,10 +556,32 @@
 	if (!nf_ct_is_confirmed(ct))
 		goto out;
 
+	dir = CTINFO2DIR(ctinfo);
+
+	qos = nf_conn_qos_find(ct);
+	if (qos) {
+		struct net *net = nf_ct_net(ct);
+
+		switch (nft_pf(pkt)) {
+		case NFPROTO_IPV4:
+			iph = ip_hdr(pkt->skb);
+			tos = iph->tos;
+			break;
+		case NFPROTO_IPV6:
+			ip6h = ipv6_hdr(pkt->skb);
+			tos = ipv6_get_dsfield(ip6h);
+			break;
+		}
+
+		qos->tos[dir].value = tos;
+		atomic64_add(1, &qos->tos[dir].counter);
+
+		if (atomic64_read(&qos->tos[dir].counter) < net->ct.sysctl_qos)
+			goto out;
+	}
+
 	if (test_and_set_bit(IPS_OFFLOAD_BIT, &ct->status))
 		goto out;
-
-	dir = CTINFO2DIR(ctinfo);
 	if (nft_flow_offload_is_bridging(pkt->skb)) {
 		if (nft_flow_route_bridging(pkt, ct, &route, dir, priv->flowtable) < 0)
 			goto err_flow_route;
@@ -542,6 +594,8 @@
 	if (!flow)
 		goto err_flow_alloc;
 
