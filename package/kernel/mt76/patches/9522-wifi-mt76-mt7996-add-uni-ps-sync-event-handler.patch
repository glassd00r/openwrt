From: Chad Monroe <chad@monroe.io>
Date: Sat, 28 Feb 2026 22:27:02 -0800
Subject: [PATCH] wifi: mt76: mt7996: enable host PS buffering

Without a PS sync event handler, mac80211 never learns when STAs enter
or leave power save. TX queues fill indefinitely for sleeping clients
and TIM is never set in beacons, preventing PS-Poll wakeup.

HOST_BROADCAST_PS_BUFFERING is not set because mac80211 forbids it for
MLO-capable drivers; broadcast/multicast PS buffering is left to
firmware.

Signed-off-by: Chad Monroe <chad@monroe.io>
---
 mt76_connac_mcu.h |    1 +
 mt7996/main.c     |    1 +
 mt7996/mcu.c      |   33 +++++++++++++++++++++++++++++++++
 mt7996/mcu.h      |   16 ++++++++++++++++
 4 files changed, 51 insertions(+)

--- a/mt76_connac_mcu.h
+++ b/mt76_connac_mcu.h
@@ -1068,6 +1068,7 @@ enum {
 	MCU_UNI_EVENT_IE_COUNTDOWN = 0x09,
 	MCU_UNI_EVENT_COREDUMP = 0x0a,
 	MCU_UNI_EVENT_BSS_BEACON_LOSS = 0x0c,
+	MCU_UNI_EVENT_PS_SYNC = 0x0d,
 	MCU_UNI_EVENT_SCAN_DONE = 0x0e,
 	MCU_UNI_EVENT_RDD_REPORT = 0x11,
 	MCU_UNI_EVENT_SR = 0x25,
--- a/mt7996/main.c
+++ b/mt7996/main.c
@@ -2548,6 +2548,7 @@ const struct ieee80211_ops mt7996_ops =
 	.cancel_hw_scan = mt76_cancel_hw_scan,
 	.remain_on_channel = mt76_remain_on_channel,
 	.cancel_remain_on_channel = mt76_cancel_remain_on_channel,
+	.set_tim = mt76_set_tim,
 	.release_buffered_frames = mt76_release_buffered_frames,
 	.get_txpower = mt7996_get_txpower,
 	.channel_switch_beacon = mt7996_channel_switch_beacon,
--- a/mt7996/mcu.c
+++ b/mt7996/mcu.c
@@ -997,6 +997,77 @@ mt7996_mcu_rx_thermal_notify(struct mt79
 }
 
 static void
+mt7996_mcu_ps_transition(struct mt7996_dev *dev, u16 wlan_idx, bool ps)
+{
+	struct ieee80211_sta *sta;
+	struct mt76_wcid *wcid;
+
+	wcid = mt76_wcid_ptr(dev, wlan_idx);
+	if (!wcid)
+		return;
+
+	sta = wcid_to_sta(wcid);
+	if (!sta)
+		return;
+
+	if (ps)
+		set_bit(MT_WCID_FLAG_PS, &wcid->flags);
+
+	ieee80211_sta_ps_transition_ni(sta, ps);
+
+	if (!ps)
+		clear_bit(MT_WCID_FLAG_PS, &wcid->flags);
+}
+
+static void
+mt7996_mcu_rx_ps_sync(struct mt7996_dev *dev, struct sk_buff *skb)
+{
+	struct mt7996_mcu_ps_client_info *info;
+	struct mt7996_mcu_ps_multi_client_info *multi;
+	u16 tag, len, wlan_idx, i;
+	u8 *bitmap;
+
+	skb_pull(skb, sizeof(struct mt7996_mcu_ps_sync_event));
+
+	info = (struct mt7996_mcu_ps_client_info *)skb->data;
+	tag = le16_to_cpu(info->tag);
+
+	rcu_read_lock();
+	switch (tag) {
+	case UNI_PS_CLIENT_INFO:
+		mt7996_mcu_ps_transition(dev, le16_to_cpu(info->wlan_idx),
+					 !!info->ps_bit);
+		break;
+	case UNI_PS_MULTI_CLIENT_INFO:
+		multi = (struct mt7996_mcu_ps_multi_client_info *)skb->data;
+		for (i = 0; i < le16_to_cpu(multi->sta_cnt); i++) {
+			u16 packed = le16_to_cpu(multi->sta_ps_info[i]);
+
+			mt7996_mcu_ps_transition(dev,
+						 FIELD_GET(MT7996_PS_MULTI_WCID, packed),
+						 !!(packed & MT7996_PS_MULTI_PS_BIT));
+		}
+		break;
+	case UNI_PS_MULTI_CLIENT_INFO_BITMAP:
+		len = le16_to_cpu(info->len);
+		bitmap = (u8 *)skb->data + sizeof(struct tlv);
+		wlan_idx = 0;
+		for (i = 0; i < len; i++) {
+			int bit;
+
+			for (bit = 0; bit < 8; bit++, wlan_idx++)
+				mt7996_mcu_ps_transition(dev, wlan_idx,
+							 !!(bitmap[i] & BIT(bit)));
+		}
+		break;
+	default:
+		dev_dbg(dev->mt76.dev, "ps_sync: unknown tag %u\n", tag);
+		break;
+	}
+	rcu_read_unlock();
+}
+
+static void
 mt7996_mcu_rx_ext_event(struct mt7996_dev *dev, struct sk_buff *skb)
 {
 	struct mt7996_mcu_rxd *rxd = (struct mt7996_mcu_rxd *)skb->data;
@@ -1110,6 +1181,9 @@ mt7996_mcu_uni_rx_unsolicited_event(stru
 	case MCU_UNI_EVENT_ALL_STA_INFO:
 		mt7996_mcu_rx_all_sta_info_event(dev, skb);
 		break;
+	case MCU_UNI_EVENT_PS_SYNC:
+		mt7996_mcu_rx_ps_sync(dev, skb);
+		break;
 	case MCU_UNI_EVENT_WED_RRO:
 		mt7996_mcu_wed_rro_event(dev, skb);
 		break;
--- a/mt7996/mcu.h
+++ b/mt7996/mcu.h
@@ -30,6 +30,38 @@ struct mt7996_mcu_uni_event {
 	__le32 status; /* 0: success, others: fail */
 } __packed;
 
+struct mt7996_mcu_ps_sync_event {
+	struct mt7996_mcu_rxd rxd;
+	u8 bss_idx;
+	u8 __rsv[3];
+} __packed;
+
+struct mt7996_mcu_ps_client_info {
+	__le16 tag;
+	__le16 len;
+	u8 ps_bit;
+	u8 __rsv;
+	__le16 wlan_idx;
+	u8 buffer_size;
+	u8 __rsv2[3];
+} __packed;
+
+struct mt7996_mcu_ps_multi_client_info {
+	__le16 tag;
+	__le16 len;
+	__le16 sta_cnt;
+	__le16 sta_ps_info[];
+} __packed;
+
+#define MT7996_PS_MULTI_WCID	GENMASK(10, 0)
+#define MT7996_PS_MULTI_PS_BIT	BIT(15)
+
+enum {
+	UNI_PS_CLIENT_INFO,
+	UNI_PS_MULTI_CLIENT_INFO,
+	UNI_PS_MULTI_CLIENT_INFO_BITMAP,
+};
+
 struct mt7996_mcu_thermal_ctrl {
 	u8 ctrl_id;
 	u8 band_idx;
