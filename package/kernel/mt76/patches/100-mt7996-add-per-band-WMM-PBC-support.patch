From: Daniel Pawlik <pawlik.dan@gmail.com>
Date: Thu, 12 Jun 2026 23:00:00 +0200
Subject: [PATCH] mt7996: add per-band WMM PBC (Packet Budget Control) support

Firmware built after 2025/12/15 changed WMM PBC from per-device to
per-band control.  Without this patch, the driver only configures PBC
on band 0, reserving all PLE pages for that band and starving 5 GHz
and 6 GHz bands of packet buffer.

This adds the complete per-band WMM PBC infrastructure:
- Periodic BSS ACQ packet count query via MCU
- Event handler to detect multi-AC traffic per band
- Per-phy work function to configure PBC bounds via firmware
- Initialization of per-band upper/lower PBC thresholds

Based on MediaTek patches 0054, 0068, and 0100 from mtk-openwrt-feeds,
squashed into final per-band form for MT7996/MT7992.

Signed-off-by: Daniel Pawlik <pawlik.dan@gmail.com>
---
diff --git a/mt76_connac_mcu.h b/mt76_connac_mcu.h
index ea2fc6c..a47de02 100644
--- a/mt76_connac_mcu.h
+++ b/mt76_connac_mcu.h
@@ -1051,6 +1051,7 @@ enum {
 	MCU_EXT_EVENT_ASSERT_DUMP = 0x23,
 	MCU_EXT_EVENT_RDD_REPORT = 0x3a,
 	MCU_EXT_EVENT_CSA_NOTIFY = 0x4f,
+	MCU_EXT_EVENT_BSS_ACQ_PKT_CNT = 0x52,
 	MCU_EXT_EVENT_WA_TX_STAT = 0x74,
 	MCU_EXT_EVENT_BCC_NOTIFY = 0x75,
 	MCU_EXT_EVENT_WF_RF_PIN_CTRL = 0x9a,
@@ -1258,6 +1259,7 @@ enum {
 	MCU_EXT_CMD_TXDPD_CAL = 0x60,
 	MCU_EXT_CMD_CAL_CACHE = 0x67,
 	MCU_EXT_CMD_RED_ENABLE = 0x68,
+	MCU_EXT_CMD_PKT_BUDGET_CTRL = 0x6c,
 	MCU_EXT_CMD_CP_SUPPORT = 0x75,
 	MCU_EXT_CMD_SET_RADAR_TH = 0x7c,
 	MCU_EXT_CMD_SET_RDD_PATTERN = 0x7d,
diff --git a/mt7996/init.c b/mt7996/init.c
index 2bf3ddd..2491c52 100644
--- a/mt7996/init.c
+++ b/mt7996/init.c
@@ -1729,6 +1729,32 @@ void mt7996_set_stream_he_eht_caps(struct mt7996_phy *phy)
 						NL80211_BAND_6GHZ);
 }
 
+static void mt7996_init_pbc(struct mt7996_dev *dev)
+{
+	struct mt7996_phy *phy;
+
+	dev->pbc_low_bound[mt76_connac_lmac_mapping(IEEE80211_AC_VO)] = 300;
+	dev->pbc_low_bound[mt76_connac_lmac_mapping(IEEE80211_AC_VI)] = 350;
+	dev->pbc_low_bound[mt76_connac_lmac_mapping(IEEE80211_AC_BE)] = 250;
+	dev->pbc_low_bound[mt76_connac_lmac_mapping(IEEE80211_AC_BK)] = 100;
+	dev->pbc_low_bound[4] = 32;
+
+	if (is_mt7996(&dev->mt76)) {
+		dev->pbc_up_bound[mt76_connac_lmac_mapping(IEEE80211_AC_VO)] = 7100;
+		dev->pbc_up_bound[mt76_connac_lmac_mapping(IEEE80211_AC_VI)] = 7100;
+		dev->pbc_up_bound[mt76_connac_lmac_mapping(IEEE80211_AC_BE)] = 6500;
+		dev->pbc_up_bound[mt76_connac_lmac_mapping(IEEE80211_AC_BK)] = 2000;
+	} else {
+		dev->pbc_up_bound[mt76_connac_lmac_mapping(IEEE80211_AC_VO)] = 3000;
+		dev->pbc_up_bound[mt76_connac_lmac_mapping(IEEE80211_AC_VI)] = 3000;
+		dev->pbc_up_bound[mt76_connac_lmac_mapping(IEEE80211_AC_BE)] = 2800;
+		dev->pbc_up_bound[mt76_connac_lmac_mapping(IEEE80211_AC_BK)] = 1100;
+	}
+	dev->pbc_up_bound[4] = 32;
+
+	mt7996_for_each_phy(dev, phy)
+		INIT_WORK(&phy->wmm_pbc_work, mt7996_mcu_wmm_pbc_work);
+}
 int mt7996_register_device(struct mt7996_dev *dev)
 {
 	struct ieee80211_hw *hw = mt76_hw(dev);
@@ -1773,6 +1799,7 @@ int mt7996_register_device(struct mt7996_dev *dev)
 	if (ret)
 		return ret;
 
+	mt7996_init_pbc(dev);
 	mt7996_for_each_phy(dev, phy)
 		mt7996_thermal_init(phy);
 
diff --git a/mt7996/mac.c b/mt7996/mac.c
index 367b51a..f4c94fb 100644
--- a/mt7996/mac.c
+++ b/mt7996/mac.c
@@ -2913,6 +2913,7 @@ void mt7996_mac_work(struct work_struct *work)
 	if (++mphy->mac_work_count == 5) {
 		mphy->mac_work_count = 0;
 
+		mt7996_mcu_get_bss_acq_pkt_cnt(phy->dev);
 		mt7996_mac_update_stats(phy);
 
 		mt7996_mcu_get_all_sta_info(phy, UNI_ALL_STA_TXRX_RATE);
diff --git a/mt7996/mcu.c b/mt7996/mcu.c
index c0b9b1b..5742993 100644
--- a/mt7996/mcu.c
+++ b/mt7996/mcu.c
@@ -730,6 +730,165 @@ mt7996_mcu_rx_thermal_notify(struct mt7996_dev *dev, struct sk_buff *skb)
 	phy->throttle_state = n->duty_percent;
 }
 
+struct mt7996_pbc_iter_data {
+	struct mt7996_dev *dev;
+	struct mt7996_mcu_bss_acq_pkt_cnt_event *event;
+};
+
+static void
+mt7996_mcu_update_pbc_pkt_cnt(void *priv, u8 *mac, struct ieee80211_vif *vif)
+{
+	struct mt7996_pbc_iter_data *data = priv;
+	struct mt7996_dev *dev = data->dev;
+	struct mt7996_mcu_bss_acq_pkt_cnt_event *event = data->event;
+	unsigned long link_id, valid_links = vif->valid_links ?: BIT(0);
+	struct mt7996_vif *mvif = (struct mt7996_vif *)vif->drv_priv;
+	u32 bitmap = le32_to_cpu(event->bss_bitmap);
+
+	rcu_read_lock();
+	for_each_set_bit(link_id, &valid_links, IEEE80211_MLD_MAX_NUM_LINKS) {
+		struct mt7996_vif_link *link;
+		struct mt76_phy *mphy;
+		struct mt7996_phy *phy;
+		u8 bss_idx, ac;
+
+		link = (struct mt7996_vif_link *)
+			rcu_dereference(mvif->mt76.link[link_id]);
+		if (!link)
+			continue;
+
+		bss_idx = link->mt76.idx;
+		if (bss_idx >= BSS_ACQ_PKT_CNT_BSS_NUM ||
+		    !(bitmap & (1 << bss_idx)))
+			continue;
+
+		mphy = mt76_dev_phy(&dev->mt76, link->mt76.band_idx);
+		phy = mphy->priv;
+
+		for (ac = IEEE80211_AC_VO; ac < IEEE80211_NUM_ACS; ++ac) {
+			u8 lmac_ac = mt76_connac_lmac_mapping(ac);
+
+			phy->pbc_pkt_cnt[ac] +=
+				le32_to_cpu(event->bss[bss_idx].cnt[lmac_ac]);
+		}
+	}
+	rcu_read_unlock();
+}
+
+static void mt7996_queue_phy_pbc_work(struct mt7996_phy *phy, bool multi_ac)
+{
+	if (multi_ac && !phy->wmm_pbc_enable) {
+		phy->wmm_pbc_enable = true;
+		queue_work(phy->dev->mt76.wq, &phy->wmm_pbc_work);
+	} else if (!multi_ac && phy->wmm_pbc_enable) {
+		phy->wmm_pbc_enable = false;
+		queue_work(phy->dev->mt76.wq, &phy->wmm_pbc_work);
+	}
+}
+
+static void
+mt7996_mcu_rx_bss_acq_pkt_cnt(struct mt7996_dev *dev, struct sk_buff *skb)
+{
+	struct mt7996_mcu_bss_acq_pkt_cnt_event *event =
+		(struct mt7996_mcu_bss_acq_pkt_cnt_event *)skb->data;
+	struct mt7996_phy *phy;
+	bool multi_ac = false;
+	u8 ac;
+
+	if (event->bss_bitmap == 0) {
+		mt7996_for_each_phy(dev, phy) {
+			u8 band = phy->mt76->band_idx;
+
+			memset(phy->pbc_pg_cnt, 0, sizeof(phy->pbc_pg_cnt));
+
+			for (ac = IEEE80211_AC_VO; ac < IEEE80211_NUM_ACS; ++ac) {
+				u8 lmac_ac = mt76_connac_lmac_mapping(ac);
+
+				phy->pbc_pg_cnt[ac] +=
+					le32_to_cpu(event->band[band].pg_cnt[lmac_ac]);
+			}
+		}
+	} else {
+		struct mt7996_pbc_iter_data iter_data = {
+			.dev = dev, .event = event
+		};
+
+		mt7996_for_each_phy(dev, phy)
+			memset(phy->pbc_pkt_cnt, 0, sizeof(phy->pbc_pkt_cnt));
+
+		ieee80211_iterate_active_interfaces_atomic(dev->mt76.hw,
+				IEEE80211_IFACE_SKIP_SDATA_NOT_IN_DRIVER,
+				mt7996_mcu_update_pbc_pkt_cnt, &iter_data);
+	}
+
+	mt7996_for_each_phy(dev, phy) {
+		u8 ac_cnt = 0;
+
+		for (ac = IEEE80211_AC_VO; ac < IEEE80211_NUM_ACS; ++ac)
+			if (phy->pbc_pg_cnt[ac] > WMM_PBC_PG_THRESHOLD ||
+			    phy->pbc_pkt_cnt[ac] > WMM_PBC_PKT_THRESHOLD)
+				++ac_cnt;
+
+		if (ac_cnt > 1)
+			multi_ac = true;
+
+		if (is_mt7992(&dev->mt76))
+			mt7996_queue_phy_pbc_work(phy, ac_cnt > 1);
+	}
+
+	if (!is_mt7992(&dev->mt76))
+		mt7996_queue_phy_pbc_work(&dev->phy, multi_ac);
+}
+
+void mt7996_mcu_wmm_pbc_work(struct work_struct *work)
+{
+#define WMM_PBC_BSS_ALL		0xff
+#define WMM_PBC_WLAN_IDX_ALL	0xffff
+#define WMM_PBC_BOUND_DEFAULT	0xffff
+	struct mt7996_phy *phy = container_of(work, struct mt7996_phy,
+					      wmm_pbc_work);
+	struct mt7996_dev *dev = phy->dev;
+	struct {
+		u8 bss_idx;
+		u8 queue_num;
+		__le16 wlan_idx;
+		u8 band_idx;
+		u8 __rsv[3];
+		struct {
+			__le16 low;
+			__le16 up;
+		} __packed bound[WMM_PBC_QUEUE_NUM];
+	} __packed req = {
+		.bss_idx = WMM_PBC_BSS_ALL,
+		.queue_num = WMM_PBC_QUEUE_NUM,
+		.wlan_idx = cpu_to_le16(WMM_PBC_WLAN_IDX_ALL),
+		.band_idx = phy->mt76->band_idx,
+	};
+	int i, ret;
+
+	for (i = 0; i < WMM_PBC_QUEUE_NUM; ++i) {
+		req.bound[i].low = phy->wmm_pbc_enable
+				   ? cpu_to_le16(dev->pbc_low_bound[i])
+				   : 0;
+		req.bound[i].up = phy->wmm_pbc_enable
+				  ? cpu_to_le16(dev->pbc_up_bound[i])
+				  : cpu_to_le16(WMM_PBC_BOUND_DEFAULT);
+	}
+
+	ret = mt76_mcu_send_msg(&dev->mt76, MCU_WA_EXT_CMD(PKT_BUDGET_CTRL),
+				&req, sizeof(req), true);
+	if (ret)
+		dev_err(dev->mt76.dev, "Failed to configure WMM PBC.\n");
+}
+
+int mt7996_mcu_get_bss_acq_pkt_cnt(struct mt7996_dev *dev)
+{
+	return mt7996_mcu_wa_cmd(dev, MCU_WA_PARAM_CMD(QUERY),
+				 MCU_WA_PARAM_BSS_ACQ_PKT_CNT,
+				 BSS_ACQ_PKT_CNT_BSS_BITMAP_ALL |
+				 BSS_ACQ_PKT_CNT_READ_CLR, 0);
+}
+
 static void
 mt7996_mcu_rx_ext_event(struct mt7996_dev *dev, struct sk_buff *skb)
 {
@@ -739,6 +898,9 @@ mt7996_mcu_rx_ext_event(struct mt7996_dev *dev, struct sk_buff *skb)
 	case MCU_EXT_EVENT_FW_LOG_2_HOST:
 		mt7996_mcu_rx_log_message(dev, skb);
 		break;
+	case MCU_EXT_EVENT_BSS_ACQ_PKT_CNT:
+		mt7996_mcu_rx_bss_acq_pkt_cnt(dev, skb);
+		break;
 	default:
 		break;
 	}
diff --git a/mt7996/mcu.h b/mt7996/mcu.h
index 55d42c9..46ad870 100644
--- a/mt7996/mcu.h
+++ b/mt7996/mcu.h
@@ -391,6 +391,7 @@ enum {
 	MCU_WA_PARAM_PDMA_RX = 0x04,
 	MCU_WA_PARAM_CPU_UTIL = 0x0b,
 	MCU_WA_PARAM_RED = 0x0e,
+	MCU_WA_PARAM_BSS_ACQ_PKT_CNT = 0x12,
 	MCU_WA_PARAM_HW_PATH_HIF_VER = 0x2f,
 };
 
@@ -1060,9 +1061,35 @@ enum {
 enum {
 	UNI_CMD_SDO_SET = 1,
 	UNI_CMD_SDO_QUERY,
-	UNI_CMD_SDO_CP_MODE = 6,
+	UNI_CMD_SDO_AUTO_BA,
+	UNI_CMD_SDO_SET_QOS_MAP,
+	UNI_CMD_SDO_HOTSPOT,
+	UNI_CMD_SDO_CP_MODE,
+	UNI_CMD_SDO_RED_SETTING,
+	UNI_CMD_SDO_PKT_BUDGET_CTRL_CFG,
+	UNI_CMD_SDO_GET_BSS_ACQ_PKT_NUM,
 };
 
+
+#define BSS_ACQ_PKT_CNT_BSS_NUM			24
+#define BSS_ACQ_PKT_CNT_BSS_BITMAP_ALL		0x00ffffff
+#define BSS_ACQ_PKT_CNT_READ_CLR		BIT(31)
+
+struct mt7996_mcu_bss_acq_pkt_cnt_event {
+	struct mt7996_mcu_rxd rxd;
+
+	__le32 bss_bitmap;
+	union {
+		struct {
+			__le32 cnt[IEEE80211_NUM_ACS];
+		} __packed bss[BSS_ACQ_PKT_CNT_BSS_NUM];
+
+		struct {
+			__le32 pg_cnt[IEEE80211_NUM_ACS];
+		} __packed band[__MT_MAX_BAND];
+	};
+} __packed;
+
 enum {
 	MT7996_SEC_MODE_PLAIN,
 	MT7996_SEC_MODE_AES,
diff --git a/mt7996/mt7996.h b/mt7996/mt7996.h
index 0d64885..f632aed 100644
--- a/mt7996/mt7996.h
+++ b/mt7996/mt7996.h
@@ -359,6 +359,10 @@ struct mt7996_msdu_page_info {
 };
 
 #define MT7996_MAX_RRO_RRS_RING 4
+
+#define WMM_PBC_QUEUE_NUM	5
+#define WMM_PBC_PKT_THRESHOLD	200
+#define WMM_PBC_PG_THRESHOLD	64
 struct mt7996_rro_queue_regs_emi {
 	struct {
 		__le16 idx;
@@ -400,6 +404,11 @@ struct mt7996_phy {
 	bool has_aux_rx;
 	bool counter_reset;
 	bool rdd_tx_paused;
+
+	bool wmm_pbc_enable;
+	struct work_struct wmm_pbc_work;
+	u64 pbc_pkt_cnt[IEEE80211_NUM_ACS];
+	u64 pbc_pg_cnt[IEEE80211_NUM_ACS];
 };
 
 struct mt7996_dev {
@@ -519,6 +528,9 @@ struct mt7996_dev {
 		u8 type:4;
 		u8 fem:4;
 	} var;
+
+	u16 pbc_low_bound[WMM_PBC_QUEUE_NUM];
+	u16 pbc_up_bound[WMM_PBC_QUEUE_NUM];
 };
 
 enum {
@@ -795,6 +807,8 @@ int mt7996_mcu_get_all_sta_info(struct mt7996_phy *phy, u16 tag);
 int mt7996_mcu_wed_rro_reset_sessions(struct mt7996_dev *dev, u16 id);
 int mt7996_mcu_set_sniffer_mode(struct mt7996_phy *phy, bool enabled);
 int mt7996_mcu_set_dup_wtbl(struct mt7996_dev *dev);
+void mt7996_mcu_wmm_pbc_work(struct work_struct *work);
+int mt7996_mcu_get_bss_acq_pkt_cnt(struct mt7996_dev *dev);
 int mt7996_mcu_mld_reconf_stop_link(struct mt7996_dev *dev,
 				    struct ieee80211_vif *vif,
 				    u16 removed_links);

